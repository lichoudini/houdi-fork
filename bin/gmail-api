#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

NODE_BIN_CANDIDATE="${NODE_BIN:-}"
if [[ -n "${NODE_BIN_CANDIDATE}" && -x "${NODE_BIN_CANDIDATE}" ]]; then
  NODE_BIN="${NODE_BIN_CANDIDATE}"
elif command -v node >/dev/null 2>&1; then
  NODE_BIN="$(command -v node)"
else
  echo "No se encontró node en PATH." >&2
  exit 1
fi

if [[ ! -f "${PROJECT_DIR}/dist/proxy/gmail-cli.js" ]]; then
  echo "Falta ${PROJECT_DIR}/dist/proxy/gmail-cli.js. Ejecuta: npm run build" >&2
  exit 1
fi

exec "${NODE_BIN}" "${PROJECT_DIR}/dist/proxy/gmail-cli.js" "$@"
