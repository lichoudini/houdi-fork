{
  "name": "operator",
  "description": "Agente operativo con allowlist de workspace y sin privilegios de sistema",
  "cwd": "./workspace",
  "workspaceOnly": true,
  "allowCommands": [
    "pwd",
    "ls",
    "find",
    "rg",
    "cat",
    "head",
    "tail",
    "sed",
    "awk",
    "cut",
    "sort",
    "uniq",
    "wc",
    "stat",
    "file",
    "mkdir",
    "cp",
    "mv",
    "rm",
    "touch",
    "echo",
    "printf",
    "git",
    "node",
    "npm",
    "npx",
    "tsx",
    "tsc",
    "curl",
    "gmail-api",
    "date",
    "whoami"
  ]
}
